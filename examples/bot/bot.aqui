// Create the head shape
rectangle head
    width: 200
    height: 250
    position: [0, 0]
circle leftEye
    radius: 30
    position: [-50, 50]
circle rightEye
    radius: 30
    position: [50, 50]
rectangle mouth
    width: 120
    height: 20
    position: [0, -40]
triangle antenna
    base: 40
    height: 60
    position: [0, 150]
layer robotFace
    add: head
    add: leftEye
    add: rightEye
    add: mouth
    add: antenna
